{
  "name": "@refuge-worldwide/calendar",
  "version": "0.1.0",
  "description": "A configurable scheduling radio calendar for Next.js",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.mjs",
      "require": "./dist/api.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.mjs",
      "require": "./dist/components.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "typesVersions": {
    "*": {
      "api": [
        "./dist/api.d.ts"
      ],
      "components": [
        "./dist/components.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsup && tailwindcss -c tailwind.config.js -i src/styles.css -o dist/styles.css --minify",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "contentful-management": ">=10",
    "next": ">=13",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.8",
    "@fullcalendar/daygrid": "^6.1.8",
    "@fullcalendar/interaction": "^6.1.8",
    "@fullcalendar/list": "^6.1.8",
    "@fullcalendar/react": "^6.1.8",
    "@fullcalendar/timegrid": "^6.1.8",
    "@radix-ui/react-dialog": "^1.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-radio-group": "^1.1.3",
    "dayjs": "^1.11.7",
    "formik": "^2.2.9",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^4.10.1",
    "react-select": "^5.6.1",
    "react-select-async-paginate": "^0.7.3",
    "rrule": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/react": "^18.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "contentful-management": "^10.29.3",
    "happy-dom": "^14.0.0",
    "next": "^13.1.1",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "^4.9.4",
    "vitest": "^2.0.0"
  }
}
